# ── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Supabase (EU project) ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Database (Supabase Postgres) ────────────────────────────────────
# pooled (pgbouncer) for the app:
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# direct for migrations:
DIRECT_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ── AI providers ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Vapi (Voice AI) ─────────────────────────────────────────────────
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=

# ── Stripe ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Price IDs (created in Stripe dashboard / fixtures):
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ANNUAL=price_...

# ── Email (Resend) ──────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="Syveka AI <no-reply@syveka.ai>"

# ── Upstash ─────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# AI chat limits are evaluated independently for each user and organization.
AI_CHAT_USER_RATE_LIMIT=30
AI_CHAT_ORG_RATE_LIMIT=300
AI_CHAT_RATE_WINDOW_SECONDS=60
AI_RETRY_MAX_ATTEMPTS=3
AI_RETRY_BASE_DELAY_MS=250
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── Observability ───────────────────────────────────────────────────
SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Calendar & Booking (V1) ─────────────────────────────────────────────
# 32-byte base64 key for AES-256-GCM encryption of OAuth tokens at rest.
# Generate: openssl rand -base64 32
CALENDAR_TOKEN_ENCRYPTION_KEY=
# HMAC secret for OAuth state (falls back to QSTASH_CURRENT_SIGNING_KEY).
CALENDAR_OAUTH_STATE_SECRET=
# Set to 1 to expose the mock provider outside development.
CALENDAR_MOCK_PROVIDER=
# Google Calendar OAuth app (redirect URI:
#   {NEXT_PUBLIC_APP_URL}/api/v1/integrations/calendar/google/callback)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
# Microsoft 365 OAuth app (redirect URI:
#   {NEXT_PUBLIC_APP_URL}/api/v1/integrations/calendar/microsoft/callback)
MICROSOFT_CALENDAR_CLIENT_ID=
MICROSOFT_CALENDAR_CLIENT_SECRET=
MICROSOFT_CALENDAR_TENANT=common
