generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgcrypto, vector]
}

// ───────────────────────── IDENTITY & TENANCY ─────────────────────────

model User {
  id          String    @id @db.Uuid
  email       String    @unique
  fullName    String?   @map("full_name")
  avatarUrl   String?   @map("avatar_url")
  locale      Locale    @default(FI)
  timezone    String    @default("Europe/Helsinki")
  onboardedAt DateTime? @map("onboarded_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  memberships   OrganizationMember[]
  notifications Notification[]
  auditLogs     AuditLog[]
  messages      Message[]
  activities    Activity[]
  documentUploadIntents DocumentUploadIntent[]

  @@map("users")
}

enum Locale {
  EN
  FI
  AR
}

model Organization {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  slug             String    @unique
  type             OrgType   @default(BUSINESS)
  logoUrl          String?   @map("logo_url")
  businessId       String?   @map("business_id")
  vatId            String?   @map("vat_id")
  defaultLocale    Locale    @default(FI)
  stripeCustomerId String?   @unique @map("stripe_customer_id")
  settings         Json      @default("{}")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  members          OrganizationMember[]
  invitations      Invitation[]
  teams            Team[]
  subscription     Subscription?
  usageRecords     UsageRecord[]
  contacts         Contact[]
  companies        Company[]
  deals            Deal[]
  pipelines        Pipeline[]
  activities       Activity[]
  calendarEvents   CalendarEvent[]
  calendarConnections   CalendarConnection[]
  externalCalendars     ExternalCalendar[]
  calendarSyncStates    CalendarSyncState[]
  availabilitySchedules AvailabilitySchedule[]
  bookingTypes          BookingType[]
  bookings              Booking[]
  reminders             Reminder[]
  conversations    Conversation[]
  documents        Document[]
  documentUploadIntents DocumentUploadIntent[]
  collections      Collection[]
  prompts          Prompt[]
  workflows        Workflow[]
  workflowRuns     WorkflowRun[]
  voiceAssistants  VoiceAssistant[]
  voiceCalls       VoiceCall[]
  notifications    Notification[]
  apiKeys          ApiKey[]
  webhookEndpoints WebhookEndpoint[]
  auditLogs        AuditLog[]
  tags             Tag[]

  @@map("organizations")
}

enum OrgType {
  PERSONAL
  BUSINESS
}

model OrganizationMember {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  role           Role     @default(MEMBER)
  teamId         String?  @map("team_id") @db.Uuid
  joinedAt       DateTime @default(now()) @map("joined_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  team         Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

model Team {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      OrganizationMember[]

  @@index([organizationId])
  @@map("teams")
}

model Invitation {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  email          String
  role           Role         @default(MEMBER)
  token          String       @unique @default(dbgenerated("gen_random_uuid()"))
  invitedById    String       @map("invited_by_id") @db.Uuid
  status         InviteStatus @default(PENDING)
  expiresAt      DateTime     @map("expires_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@map("invitations")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

// ───────────────────────── BILLING ─────────────────────────

model Subscription {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId       String    @unique @map("organization_id") @db.Uuid
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  plan                 Plan      @default(FREE)
  status               SubStatus @default(ACTIVE)
  seats                Int       @default(1)
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  trialEndsAt          DateTime? @map("trial_ends_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum SubStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
  PAUSED
}

model UsageRecord {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  metric         UsageMetric
  quantity       Int
  periodStart    DateTime    @map("period_start")
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, metric, periodStart])
  @@map("usage_records")
}

enum UsageMetric {
  AI_TOKENS_IN
  AI_TOKENS_OUT
  AI_MESSAGES
  VOICE_MINUTES
  EMBEDDINGS
  STORAGE_MB
  WORKFLOW_RUNS
  API_CALLS
}

// ───────────────────────── CRM ─────────────────────────

model Company {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  domain         String?
  businessId     String?   @map("business_id")
  industry       String?
  size           String?
  website        String?
  address        Json?
  customFields   Json      @default("{}") @map("custom_fields")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  archivedAt     DateTime? @map("archived_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  deals        Deal[]
  activities   Activity[]

  @@index([organizationId])
  @@index([organizationId, name])
  @@map("companies")
}

model Contact {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  companyId      String?       @map("company_id") @db.Uuid
  ownerId        String?       @map("owner_id") @db.Uuid
  firstName      String        @map("first_name")
  lastName       String?       @map("last_name")
  email          String?
  phone          String?
  title          String?
  status         ContactStatus @default(LEAD)
  source         String?
  locale         Locale?
  gdprConsentAt  DateTime?     @map("gdpr_consent_at")
  customFields   Json          @default("{}") @map("custom_fields")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  archivedAt     DateTime?     @map("archived_at")
  deletedAt      DateTime?     @map("deleted_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deals          Deal[]
  activities     Activity[]
  tags           TagsOnContacts[]
  eventAttendees EventAttendee[]

  @@index([organizationId, status])
  @@index([organizationId, email])
  @@map("contacts")
}

enum ContactStatus {
  LEAD
  PROSPECT
  CUSTOMER
  CHURNED
  ARCHIVED
}

model Pipeline {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  name           String
  isDefault      Boolean @default(false) @map("is_default")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stages       PipelineStage[]
  deals        Deal[]

  @@index([organizationId])
  @@map("pipelines")
}

model PipelineStage {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pipelineId  String  @map("pipeline_id") @db.Uuid
  name        String
  order       Int
  probability Int     @default(0)
  isWon       Boolean @default(false) @map("is_won")
  isLost      Boolean @default(false) @map("is_lost")

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@unique([pipelineId, order])
  @@map("pipeline_stages")
}

model Deal {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  pipelineId      String    @map("pipeline_id") @db.Uuid
  stageId         String    @map("stage_id") @db.Uuid
  contactId       String?   @map("contact_id") @db.Uuid
  companyId       String?   @map("company_id") @db.Uuid
  ownerId         String?   @map("owner_id") @db.Uuid
  title           String
  valueCents      Int       @default(0) @map("value_cents")
  currency        String    @default("EUR")
  probability     Int?
  position        Int       @default(0)
  expectedCloseAt DateTime? @map("expected_close_at")
  closedAt        DateTime? @map("closed_at")
  lostReason      String?   @map("lost_reason")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline     Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage        PipelineStage @relation(fields: [stageId], references: [id])
  contact      Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  activities   Activity[]

  @@index([organizationId, stageId])
  @@index([organizationId, closedAt])
  @@index([organizationId, pipelineId, closedAt])
  @@index([organizationId, ownerId])
  @@map("deals")
}

model Activity {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String?      @map("user_id") @db.Uuid
  contactId      String?      @map("contact_id") @db.Uuid
  companyId      String?      @map("company_id") @db.Uuid
  dealId         String?      @map("deal_id") @db.Uuid
  type           ActivityType
  subject        String
  body           String?
  dueAt          DateTime?    @map("due_at")
  completedAt    DateTime?    @map("completed_at")
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deal         Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([organizationId, dueAt])
  @@index([organizationId, type, dueAt])
  @@index([organizationId, type, createdAt])
  @@index([contactId])
  @@index([companyId])
  @@map("activities")
}

enum ActivityType {
  NOTE
  TASK
  CALL
  EMAIL
  MEETING
  VOICE_AI_CALL
  AI_SUMMARY
  STAGE_CHANGE
}

model Tag {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  name           String
  color          String @default("#6366f1")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     TagsOnContacts[]

  @@unique([organizationId, name])
  @@map("tags")
}

model TagsOnContacts {
  contactId String @map("contact_id") @db.Uuid
  tagId     String @map("tag_id") @db.Uuid

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("tags_on_contacts")
}

// ───────────────────────── CALENDAR & BOOKING ─────────────────────────

model CalendarEvent {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  createdById    String      @map("created_by_id") @db.Uuid
  ownerId        String?     @map("owner_id") @db.Uuid
  title          String
  description    String?
  location       String?
  timezone       String      @default("Europe/Helsinki")
  startsAt       DateTime    @map("starts_at")
  endsAt         DateTime    @map("ends_at")
  allDay         Boolean     @default(false) @map("all_day")
  recurrenceRule String?     @map("recurrence_rule")
  status         EventStatus @default(CONFIRMED)
  contactId      String?     @map("contact_id") @db.Uuid
  companyId      String?     @map("company_id") @db.Uuid
  dealId         String?     @map("deal_id") @db.Uuid
  source         EventSource @default(MANUAL)
  externalCalendarId String? @map("external_calendar_id") @db.Uuid
  externalId     String?     @map("external_id")
  externalEtag   String?     @map("external_etag")
  attendees      Json        @default("[]") // deprecated: use EventAttendee rows
  canceledAt     DateTime?   @map("canceled_at")
  deletedAt      DateTime?   @map("deleted_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  externalCalendar ExternalCalendar? @relation(fields: [externalCalendarId], references: [id], onDelete: SetNull)
  attendeeRecords  EventAttendee[]
  booking          Booking?
  reminders        Reminder[]

  @@unique([externalCalendarId, externalId])
  @@index([organizationId, startsAt])
  @@index([organizationId, ownerId, startsAt])
  @@index([organizationId, contactId, startsAt])
  @@index([organizationId, companyId, startsAt])
  @@index([organizationId, dealId, startsAt])
  @@map("calendar_events")
}

enum EventSource {
  MANUAL
  VOICE_AI
  WORKFLOW
  BOOKING
  GOOGLE
  OUTLOOK
}

enum EventStatus {
  CONFIRMED
  TENTATIVE
  CANCELED
}

/// Tenant-scoped via parent CalendarEvent (like Message → Conversation).
model EventAttendee {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId     String         @map("event_id") @db.Uuid
  contactId   String?        @map("contact_id") @db.Uuid
  userId      String?        @map("user_id") @db.Uuid
  email       String?
  name        String?
  status      AttendeeStatus @default(PENDING)
  isOrganizer Boolean        @default(false) @map("is_organizer")
  createdAt   DateTime       @default(now()) @map("created_at")

  event   CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  contact Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([contactId])
  @@map("event_attendees")
}

enum AttendeeStatus {
  PENDING
  ACCEPTED
  DECLINED
  TENTATIVE
}

model CalendarConnection {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String             @map("organization_id") @db.Uuid
  userId          String             @map("user_id") @db.Uuid
  provider        CalendarProvider
  accountEmail    String?            @map("account_email")
  accessTokenEnc  String?            @map("access_token_enc")
  refreshTokenEnc String?            @map("refresh_token_enc")
  tokenExpiresAt  DateTime?          @map("token_expires_at")
  scopes          String[]           @default([])
  status          ConnectionStatus   @default(CONNECTED)
  lastError       String?            @map("last_error")
  lastCheckedAt   DateTime?          @map("last_checked_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  calendars    ExternalCalendar[]

  @@unique([organizationId, userId, provider])
  @@index([organizationId])
  @@map("calendar_connections")
}

enum CalendarProvider {
  GOOGLE
  MICROSOFT
  MOCK
}

enum ConnectionStatus {
  CONNECTED
  NEEDS_REAUTH
  ERROR
  DISCONNECTED
}

model ExternalCalendar {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  connectionId   String   @map("connection_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  externalId     String   @map("external_id")
  name           String
  isPrimary      Boolean  @default(false) @map("is_primary")
  syncEnabled    Boolean  @default(false) @map("sync_enabled")
  timezone       String?
  createdAt      DateTime @default(now()) @map("created_at")

  connection   CalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events       CalendarEvent[]
  syncState    CalendarSyncState?

  @@unique([connectionId, externalId])
  @@index([organizationId])
  @@map("external_calendars")
}

/// Sync cursor + webhook subscription state per external calendar.
model CalendarSyncState {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId        String    @map("organization_id") @db.Uuid
  externalCalendarId    String    @unique @map("external_calendar_id") @db.Uuid
  syncCursor            String?   @map("sync_cursor")
  webhookSubscriptionId String?   @map("webhook_subscription_id")
  webhookResourceId     String?   @map("webhook_resource_id")
  webhookExpiresAt      DateTime? @map("webhook_expires_at")
  lastSyncedAt          DateTime? @map("last_synced_at")
  lastSyncStatus        String?   @map("last_sync_status")
  failureCount          Int       @default(0) @map("failure_count")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  externalCalendar ExternalCalendar @relation(fields: [externalCalendarId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("calendar_sync_states")
}

model AvailabilitySchedule {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  name           String
  timezone       String   @default("Europe/Helsinki")
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rules        AvailabilityRule[]
  overrides    AvailabilityOverride[]
  bookingTypes BookingType[]

  @@index([organizationId, userId])
  @@map("availability_schedules")
}

/// Weekly recurring working window. Tenant-scoped via parent schedule.
model AvailabilityRule {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scheduleId  String @map("schedule_id") @db.Uuid
  weekday     Int // 0 = Sunday … 6 = Saturday
  startMinute Int    @map("start_minute") // minutes from local midnight
  endMinute   Int    @map("end_minute")

  schedule AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId, weekday])
  @@map("availability_rules")
}

/// Date-specific override. Tenant-scoped via parent schedule.
model AvailabilityOverride {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scheduleId    String   @map("schedule_id") @db.Uuid
  date          DateTime @db.Date
  startMinute   Int?     @map("start_minute")
  endMinute     Int?     @map("end_minute")
  isUnavailable Boolean  @default(false) @map("is_unavailable")

  schedule AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId, date])
  @@map("availability_overrides")
}

model BookingType {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String       @map("organization_id") @db.Uuid
  ownerId             String       @map("owner_id") @db.Uuid
  scheduleId          String?      @map("schedule_id") @db.Uuid
  slug                String
  name                String
  description         String?
  durationMinutes     Int          @default(30) @map("duration_minutes")
  durationOptions     Int[]        @default([30]) @map("duration_options")
  locationType        LocationType @default(VIDEO) @map("location_type")
  location            String?
  bufferBeforeMinutes Int          @default(0) @map("buffer_before_minutes")
  bufferAfterMinutes  Int          @default(0) @map("buffer_after_minutes")
  minNoticeMinutes    Int          @default(120) @map("min_notice_minutes")
  maxWindowDays       Int          @default(60) @map("max_window_days")
  brandColor          String?      @map("brand_color")
  confirmationMessage String?      @map("confirmation_message")
  collectPhone        Boolean      @default(false) @map("collect_phone")
  collectCompany      Boolean      @default(false) @map("collect_company")
  requiresConsent     Boolean      @default(true) @map("requires_consent")
  isActive            Boolean      @default(true) @map("is_active")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")
  deletedAt           DateTime?    @map("deleted_at")

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  schedule     AvailabilitySchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  bookings     Booking[]

  @@unique([organizationId, slug])
  @@index([organizationId, isActive])
  @@map("booking_types")
}

enum LocationType {
  VIDEO
  PHONE
  IN_PERSON
  CUSTOM
}

model Booking {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String        @map("organization_id") @db.Uuid
  bookingTypeId     String        @map("booking_type_id") @db.Uuid
  eventId           String?       @unique @map("event_id") @db.Uuid
  guestName         String        @map("guest_name")
  guestEmail        String        @map("guest_email")
  guestPhone        String?       @map("guest_phone")
  guestCompany      String?       @map("guest_company")
  guestNotes        String?       @map("guest_notes")
  guestTimezone     String        @default("Europe/Helsinki") @map("guest_timezone")
  guestLocale       Locale?       @map("guest_locale")
  consentAt         DateTime?     @map("consent_at")
  status            BookingStatus @default(CONFIRMED)
  startsAt          DateTime      @map("starts_at")
  endsAt            DateTime      @map("ends_at")
  canceledAt        DateTime?     @map("canceled_at")
  cancelReason      String?       @map("cancel_reason")
  rescheduledFromId String?       @map("rescheduled_from_id") @db.Uuid
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookingType     BookingType   @relation(fields: [bookingTypeId], references: [id], onDelete: Cascade)
  event           CalendarEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  rescheduledFrom Booking?      @relation("BookingReschedule", fields: [rescheduledFromId], references: [id], onDelete: SetNull)
  rescheduledTo   Booking[]     @relation("BookingReschedule")
  tokens          BookingToken[]

  @@index([organizationId, startsAt])
  @@index([organizationId, status, startsAt])
  @@index([bookingTypeId, startsAt])
  @@map("bookings")
}

enum BookingStatus {
  CONFIRMED
  RESCHEDULED
  CANCELED
  COMPLETED
}

/// Secure expiring token for public cancel/reschedule links.
/// Only a SHA-256 hash is stored. Tenant-scoped via parent booking.
model BookingToken {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId String              @map("booking_id") @db.Uuid
  tokenHash String              @unique @map("token_hash")
  purpose   BookingTokenPurpose
  expiresAt DateTime            @map("expires_at")
  usedAt    DateTime?           @map("used_at")
  createdAt DateTime            @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_tokens")
}

enum BookingTokenPurpose {
  MANAGE
  CANCEL
  RESCHEDULE
}

model Reminder {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  eventId   String?         @map("event_id") @db.Uuid
  channel   ReminderChannel @default(EMAIL)
  sendAt    DateTime        @map("send_at")
  sentAt    DateTime?       @map("sent_at")
  status    ReminderStatus  @default(SCHEDULED)
  dedupeKey String          @unique @map("dedupe_key")
  attempts  Int             @default(0)
  lastError String?         @map("last_error")
  createdAt DateTime        @default(now()) @map("created_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event        CalendarEvent? @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, sendAt])
  @@map("reminders")
}

enum ReminderChannel {
  EMAIL
  IN_APP
}

enum ReminderStatus {
  SCHEDULED
  SENT
  FAILED
  CANCELED
}


// ───────────────────────── AI: CHAT ─────────────────────────

model Conversation {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  title          String    @default("New conversation")
  model          String?
  systemPromptId String?   @map("system_prompt_id") @db.Uuid
  isPinned       Boolean   @default(false) @map("is_pinned")
  isShared       Boolean   @default(false) @map("is_shared")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@index([organizationId, userId, updatedAt])
  @@index([organizationId, updatedAt])
  @@map("conversations")
}

model Message {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String      @map("conversation_id") @db.Uuid
  userId         String?     @map("user_id") @db.Uuid
  role           MessageRole
  content        String
  model          String?
  tokensIn       Int?        @map("tokens_in")
  tokensOut      Int?        @map("tokens_out")
  latencyMs      Int?        @map("latency_ms")
  toolCalls      Json?       @map("tool_calls")
  citations      Json?
  feedback       Int?
  createdAt      DateTime    @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@map("messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

// ───────────────────────── AI: KNOWLEDGE BASE ─────────────────────────

model Collection {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents    Document[]

  @@index([organizationId])
  @@map("collections")
}

model Document {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  collectionId   String?   @map("collection_id") @db.Uuid
  uploadedById   String    @map("uploaded_by_id") @db.Uuid
  title          String
  sourceType     DocSource @map("source_type")
  storagePath    String?   @map("storage_path")
  sourceUrl      String?   @map("source_url")
  mimeType       String?   @map("mime_type")
  sizeBytes      Int?      @map("size_bytes")
  language       Locale?
  status         DocStatus @default(PENDING)
  error          String?
  chunkCount     Int       @default(0) @map("chunk_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  collection   Collection?     @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  chunks       DocumentChunk[]

  @@index([organizationId, status])
  @@map("documents")
}

model DocumentUploadIntent {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String    @map("organization_id") @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  storagePath      String    @unique @map("storage_path")
  expectedMimeType String    @map("expected_mime_type")
  maxSizeBytes     Int       @map("max_size_bytes")
  expiresAt        DateTime  @map("expires_at")
  usedAt           DateTime? @map("used_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, expiresAt])
  @@map("document_upload_intents")
}

enum DocSource {
  UPLOAD
  URL
  NOTE
  FAQ
  INTEGRATION
}

enum DocStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model DocumentChunk {
  id             String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId     String                       @map("document_id") @db.Uuid
  organizationId String                       @map("organization_id") @db.Uuid
  chunkIndex     Int                          @map("chunk_index")
  content        String
  tokenCount     Int                          @map("token_count")
  embedding      Unsupported("vector(1536)")?
  metadata       Json                         @default("{}")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([organizationId])
  @@map("document_chunks")
}

// ───────────────────────── AI: PROMPT LIBRARY ─────────────────────────

model Prompt {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
